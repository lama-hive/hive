{
    "name": "lamahive/hive",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Lamahive\\Hive\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Jakub Hluchý",
            "email": "hluchjak@outlook.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "slim/slim": "4.*",
        "slim/psr7": "^1.5",
        "psr/container": "^1.0",
        "php-di/slim-bridge": "^3.2",
        "twig/twig": "^3.0",
        "slim/twig-view": "^3.3",
        "monolog/monolog": "^3.4"
    },
    "require-dev": {
        "pestphp/pest": "^2.17",
        "squizlabs/php_codesniffer": "*"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
